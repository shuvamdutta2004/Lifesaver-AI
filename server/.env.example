# ============================================================
# LifeSaver AI – Server Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# ── Supabase / PostgreSQL (Prisma) ───────────────────────────
# HOW TO GET THESE:
#  1. Go to https://supabase.com → create a project
#  2. Project Settings → Database → Connection string
#     → Mode: URI → copy the URL (replace [YOUR-PASSWORD])
#
# DATABASE_URL  → "Transaction" pooler URL (port 6543) — used at runtime
# DIRECT_URL    → Direct connection URL    (port 5432) — used for migrations
#
DATABASE_URL="postgresql://postgres.YOURPROJECTREF:YOURPASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOURPROJECTREF:YOURPASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

PORT=4000
NODE_ENV=development

# Frontend URL (for CORS whitelist)
# Add your Vercel deployment URL here too (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR_VERCEL_URL.vercel.app

# ── Google Gemini AI ─────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Model used: gemini-1.5-flash (free tier, fast)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Ollama (local free AI, no API key) ───────────────────────
# Install: https://ollama.com
# Run once: ollama run llama3.2
# Keep OLLAMA_ENABLED=true to try Ollama first in /api/ai
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI-compatible AI (optional fallback) ─────────────────
# Use official OpenAI or compatible providers like AIMLAPI.
# Examples:
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_BASE_URL=https://api.aimlapi.com/v1
OPENAI_API_KEY=YOUR_OPENAI_OR_COMPATIBLE_KEY
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Directions / Routing (shortest + safest) ─────────────────
# Free key: https://openrouteservice.org/dev/#/signup
# If ORS key is missing, backend auto-falls back to public OSRM.
ORS_API_KEY=YOUR_OPENROUTESERVICE_KEY
ORS_BASE_URL=https://api.openrouteservice.org
OSRM_BASE_URL=https://router.project-osrm.org
ROUTE_SNAP_RADIUS_METERS=3000
# Avoid ORS API error code 2004 for very long routes (defaults to ORS limit).
ORS_MAX_ROUTE_DISTANCE_METERS=150000

# ── Firebase Admin SDK ───────────────────────────────────────
# Download from: Firebase Console → Project Settings → Service Accounts
# → Generate new private key → save as server/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com

# ── Twilio SMS (optional – for real emergency contacts) ──────
# Get from: https://console.twilio.com
# TWILIO_PHONE_NUMBER must be a Twilio-owned number in E.164 format.
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1234567890
# Add at least two verified recipient numbers (comma-separated) for /api/twilio/test-sms/demo.
TWILIO_DEMO_NUMBERS=+911111111111,+912222222222

# ── Twilio broadcast controls ────────────────────────────────
# Hospitals receive SMS by default for trial/demo visibility.
BROADCAST_HOSPITAL_MODE=sms
BROADCAST_HOSPITAL_SMS_MAX=5
BROADCAST_HELPER_SMS_MAX=5
BROADCAST_CONTACT_SMS_MAX=3

# For normal Indian numbers in seed data (044..., 10-digit mobile, etc.)
DEFAULT_PHONE_COUNTRY_CODE=91
